{
  "servers": {
    "shadcn": {
      "command": "npx",
      "args": ["shadcn@latest", "mcp"]
    },
    "supabase": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "supabase-mcp-server@latest"],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "${input:supabase_access_token}",
        "SUPABASE_PROJECT_ID": "aezahmzfhugaxpfhqumn"
      }
    },
    "vercel": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "vercel-mcp@latest"],
      "env": {
        "VERCEL_API_TOKEN": "${input:vercel_api_token}"
      }
    },
    "unipile": {
      "type": "http",
      "url": "https://developer.unipile.com/mcp",
      "headers": {
        "X-API-KEY": "${input:unipile_api_key}"
      }
    }
  },
  "inputs": [
    {
      "id": "supabase_access_token",
      "type": "promptString",
      "description": "Supabase Access Token",
      "password": true
    },
    {
      "id": "vercel_api_token",
      "type": "promptString",
      "description": "Vercel API Token",
      "password": true
    },
    {
      "id": "unipile_api_key",
      "type": "promptString",
      "description": "Unipile API Key",
      "password": true
    }
  ]
}
